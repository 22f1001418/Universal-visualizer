# ── Required ─────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...

# ── Models ───────────────────────────────────────────
OPENAI_TEXT_MODEL=gpt-4o-mini
# REASONING_EFFORT=low

# ── Token / cost guard ───────────────────────────────
TOKEN_BUDGET_PER_JOB=300000
MAX_OUTPUT_TOKENS=4096

# ── Paths ────────────────────────────────────────────
# In Docker/Railway, fixed_main_v6.py is at /app/fixed_main_v6.py (set in Dockerfile ENV).
# For local dev the default (same directory as orchestrator.py) works without this.
# FIXED_MAIN_PATH=/app/fixed_main_v6.py

# Where generated Vite projects are stored.
# On Railway, mount a persistent volume at /app/viz_outputs and set this:
# VIZ_OUTPUT_DIR=/app/viz_outputs

# How long a single build is allowed to run.
BUILD_TIMEOUT_SECONDS=1200

# ── GitHub publish (per-program repo → Vercel) ───────
# Each successful build is pushed into the program's GitHub repo at
# <module>/<viz>/ on main; Vercel auto-deploys and serves the viz.
# Token needs the `repo` scope (and `admin:org` only if GITHUB_OWNER is an org).
# GITHUB_TOKEN=ghp_...
#
# Optional. Leave unset to publish under the token's own user account.
# Set to a user OR org login to publish there instead (auto-detected).
# GITHUB_OWNER=your-org-or-user
#
# Master switch. Set to false to disable publishing even when GITHUB_TOKEN is set.
PUBLISH_TO_GITHUB=true
# Create repos as private. Default false (public).
GITHUB_REPOS_PRIVATE=false
# Per-program viz repos (JSON: track -> {repo, vercel_base}). Maps each upload
# `track` to the GitHub repo that stores its vizzes and the Vercel base URL that
# serves them. One repo can back several tracks. Each repo is imported once into
# Vercel; pushes to main auto-deploy. Configure your real values in .env, e.g.:
# PROGRAM_REPOS={"AIML":{"repo":"viz-aiml","vercel_base":"https://viz-aiml.vercel.app"},"DevOps":{"repo":"viz-devops","vercel_base":"https://viz-devops.vercel.app"}}

# ── Per-task model overrides (Stage 1 modularization) ────
# All optional. If unset, each LLMTask uses its built-in default:
#   AGENT_A_EXTRACT     → gpt-4o-mini
#   AGENT_B_SUGGEST     → gpt-4o-mini
#   VIZ_TOPIC_CLASSIFY  → gpt-4o-mini
#   VIZ_DRAFT           → gpt-4o     (the only heavy default)
#   VIZ_BUILD_FIX       → gpt-4o-mini
#   VIZ_RUNTIME_FIX     → gpt-4o-mini
#   VIZ_POLISH          → gpt-4o-mini
# Setting any of these overrides the corresponding task's model.
# MODEL_AGENT_A=gpt-4o-mini
# MODEL_AGENT_B=gpt-4o-mini
# MODEL_VIZ_CLASSIFY=gpt-4o-mini
# MODEL_VIZ_DRAFT=gpt-4o
# MODEL_VIZ_FIX=gpt-4o-mini
# MODEL_VIZ_RUNTIME=gpt-4o-mini
# MODEL_VIZ_POLISH=gpt-4o-mini

# ── Server ───────────────────────────────────────────
PORT=8001
# HOST defaults to 0.0.0.0 (Docker/Railway). Set to 127.0.0.1 for local-only.
HOST=0.0.0.0

# For local dev, restrict CORS. In production, set to your Railway domain:
# ALLOWED_ORIGINS=https://your-app.up.railway.app
ALLOWED_ORIGINS=http://127.0.0.1:8001,http://localhost:8001
