# ── Required ─────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...

# ── Models ───────────────────────────────────────────
OPENAI_TEXT_MODEL=gpt-4o-mini
# REASONING_EFFORT=low

# ── Token / cost guard ───────────────────────────────
TOKEN_BUDGET_PER_JOB=300000
MAX_OUTPUT_TOKENS=4096

# ── Paths ────────────────────────────────────────────
# In Docker/Railway, fixed_main_v6.py is at /app/fixed_main_v6.py (set in Dockerfile ENV).
# For local dev the default (same directory as orchestrator.py) works without this.
# FIXED_MAIN_PATH=/app/fixed_main_v6.py

# Where generated Vite projects are stored.
# On Railway, mount a persistent volume at /app/viz_outputs and set this:
# VIZ_OUTPUT_DIR=/app/viz_outputs

# How long a single build is allowed to run.
BUILD_TIMEOUT_SECONDS=1200

# ── Static build (production) ────────────────────────
# After a successful viz generation, run `npm run build` to produce a
# deployable dist/ folder, served at /viz/<slug>/dist/index.html.
# Set false only if you want to skip the build step (e.g. pure local dev).
BUILD_STATIC=true

# ── Auto-launched dev servers (local dev only) ───────
# Runs `npm run dev` so you get hot-reload in local dev.
# Set false in production — dev servers bind localhost ports not reachable externally.
AUTO_START_DEV_SERVER=true
AUDIT_FIX_ENABLED=false

DEV_SERVER_PORT_START=5180
DEV_SERVER_PORT_END=5230
PREVIEW_BOOT_WAIT=45
NPM_INSTALL_TIMEOUT=300

# ── Server ───────────────────────────────────────────
PORT=8001
# HOST defaults to 0.0.0.0 (Docker/Railway). Set to 127.0.0.1 for local-only.
HOST=0.0.0.0

# For local dev, restrict CORS. In production, set to your Railway domain:
# ALLOWED_ORIGINS=https://your-app.up.railway.app
ALLOWED_ORIGINS=http://127.0.0.1:8001,http://localhost:8001
