# ── Required ─────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...

# ── Models ───────────────────────────────────────────
# Text model used by the topic-extraction and viz-suggestion agents.
# For reasoning models (gpt-5*, o1*, o3*, o4*) the orchestrator
# automatically uses max_completion_tokens + reasoning_effort.
OPENAI_TEXT_MODEL=gpt-4o-mini
# REASONING_EFFORT=low

# ── Token / cost guard ───────────────────────────────
TOKEN_BUDGET_PER_JOB=300000
MAX_OUTPUT_TOKENS=4096

# ── Paths ────────────────────────────────────────────
# Absolute path to the viz generator CLI (fixed_main_v6.py from the
# previous build). The orchestrator runs it as a subprocess.
FIXED_MAIN_PATH=/Users/yourname/path/to/fixed_main_v6.py

# Where the generated Vite project trees should be created.
# This becomes the cwd for the subprocess. Default: ./viz_outputs
# VIZ_OUTPUT_DIR=/Users/yourname/viz_outputs

# How long a single build is allowed to run before the orchestrator kills it.
BUILD_TIMEOUT_SECONDS=1200

# ── Auto-launched dev servers ────────────────────────
# After a successful build, the orchestrator runs:
#   1. npm install
#   2. npm audit fix --force      (skip with AUDIT_FIX_ENABLED=false)
#   3. npm run dev -- --port <unique>
# and shows you a clickable "Open Live Preview" button in the UI.
AUTO_START_DEV_SERVER=true
AUDIT_FIX_ENABLED=true

# Each viz gets a unique port from this range. Increase the upper bound if
# you plan to keep many dev servers running at once.
DEV_SERVER_PORT_START=5180
DEV_SERVER_PORT_END=5230

# How long to wait for vite to bind to its port before giving up.
PREVIEW_BOOT_WAIT=45
NPM_INSTALL_TIMEOUT=300

# ── Server ───────────────────────────────────────────
PORT=8001
ALLOWED_ORIGINS=http://127.0.0.1:8001,http://localhost:8001
